<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.xaml" />
        <ResourceDictionary Source="MaterialDesignTheme.Font.xaml" />
        <ResourceDictionary Source="Type/Typography.xaml" />
        <ResourceDictionary Source="Shapes/Shapes.xaml" />
        <ResourceDictionary Source="Elevation.xaml" />
        <ResourceDictionary Source="Motion/Motion.xaml" />

        <!-- Controls -->
        <ResourceDictionary Source="../Controls/Icon/PackIcon.xaml" />
        <ResourceDictionary Source="../Controls/SymbolIcon/SymbolIcon.xaml" />
        <ResourceDictionary Source="../Controls/Ripple/Ripple.xaml" />
        <ResourceDictionary Source="../Controls/Button/Button.xaml" />
        <ResourceDictionary Source="../Controls/Button/IconButton.xaml" />
        <ResourceDictionary Source="../Controls/Card/Card.xaml" />
        <ResourceDictionary Source="../Controls/TextField/TextField.xaml" />
        <ResourceDictionary Source="../Controls/ComboBox/ComboBox.xaml" />
        <ResourceDictionary Source="../Controls/Checkbox/Checkbox.xaml" />
        <ResourceDictionary Source="../Controls/Switch/Switch.xaml" />
        <ResourceDictionary Source="../Controls/RadioButton/RadioButton.xaml" />
        <ResourceDictionary Source="../Controls/FloatingActionButton/FloatingActionButton.xaml" />
        <ResourceDictionary Source="../Controls/NavigationRail/NavigationRail.xaml" />
        <ResourceDictionary Source="../Controls/NavigationDrawer/NavigationDrawer.xaml" />
        <ResourceDictionary Source="../Controls/Chips/Chips.xaml" />
        <ResourceDictionary Source="../Controls/Progress/Progress.xaml" />
        <ResourceDictionary Source="../Controls/Dialog/Dialog.xaml" />
        <ResourceDictionary Source="../Controls/Tabs/Tabs.xaml" />
        <ResourceDictionary Source="../Controls/Snackbar/Snackbar.xaml" />
        <ResourceDictionary Source="../Controls/Slider/Slider.xaml" />
        <ResourceDictionary Source="../Controls/Badge/Badge.xaml" />
        <ResourceDictionary Source="../Controls/List/List.xaml" />
        <ResourceDictionary Source="../Controls/Divider/Divider.xaml" />
        <ResourceDictionary Source="../Controls/Menu/Menu.xaml" />
        <ResourceDictionary Source="../Controls/ToolTip/ToolTip.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Global Implicit Styles -->
    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource MaterialDesignMenuItem}" />
    <Style TargetType="{x:Type ContextMenu}" BasedOn="{StaticResource MaterialDesignContextMenu}" />
    <Style TargetType="{x:Type Menu}" BasedOn="{StaticResource MaterialDesignMenu}" />

</ResourceDictionary>
