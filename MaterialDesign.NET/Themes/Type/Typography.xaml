<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="MdRefTypeface.Brand">Roboto, Segoe UI</FontFamily>
    <FontFamily x:Key="MdRefTypeface.Plain">Roboto, Segoe UI</FontFamily>

    <FontWeight x:Key="MdRefTypeface.WeightBold">Bold</FontWeight> <!-- 700 -->
    <FontWeight x:Key="MdRefTypeface.WeightMedium">Medium</FontWeight> <!-- 500 -->
    <FontWeight x:Key="MdRefTypeface.WeightRegular">Normal</FontWeight> <!-- 400 -->

    <!-- Display -->
    <Style x:Key="MdSysTypescale.DisplayLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="57" /> <!-- 3.5625rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.DisplayMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="45" /> <!-- 2.8125rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.DisplaySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="36" /> <!-- 2.25rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>

    <!-- Headline -->
    <Style x:Key="MdSysTypescale.HeadlineLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="32" /> <!-- 2rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.HeadlineMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="28" /> <!-- 1.75rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.HeadlineSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="24" /> <!-- 1.5rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>

    <!-- Title -->
    <Style x:Key="MdSysTypescale.TitleLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="22" /> <!-- 1.375rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.TitleMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="16" /> <!-- 1rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
    </Style>
    <Style x:Key="MdSysTypescale.TitleSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="14" /> <!-- 0.875rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
    </Style>

    <!-- Body -->
    <Style x:Key="MdSysTypescale.BodyLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="16" /> <!-- 1rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.BodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="14" /> <!-- 0.875rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>
    <Style x:Key="MdSysTypescale.BodySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="12" /> <!-- 0.75rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightRegular}" />
    </Style>

    <!-- Label -->
    <Style x:Key="MdSysTypescale.LabelLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="14" /> <!-- 0.875rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
    </Style>
    <Style x:Key="MdSysTypescale.LabelMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="12" /> <!-- 0.75rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
    </Style>
    <Style x:Key="MdSysTypescale.LabelSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Plain}" />
        <Setter Property="FontSize" Value="11" /> <!-- 0.6875rem * 16 -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
    </Style>

</ResourceDictionary>
