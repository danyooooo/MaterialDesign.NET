<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converters:SelectedIndexToBoolConverter x:Key="SelectedIndexToBoolConverter" />

    <!-- Toggle Button for ComboBox -->
    <Style x:Key="MaterialDesignComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled ComboBox -->
    <Style x:Key="MaterialDesignFilledComboBoxStyle" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurfaceVariant}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,24,16,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Bottom" />
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Input Container -->
                        <Grid Grid.Row="0" Height="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Container"
                                    Grid.ColumnSpan="3"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4,4,0,0"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True" />
                            
                            <!-- Focus Indicator -->
                            <Border x:Name="FocusIndicator"
                                    Grid.ColumnSpan="3"
                                    Background="{DynamicResource MdSysColor.Primary}"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Visibility="Collapsed" />
                            
                             <!-- Trailing Icon (DropDown Arrow) -->
                            <Path Grid.Column="2" 
                                  x:Name="Arrow"
                                  Data="M7,10L12,15L17,10H7Z" 
                                  Fill="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"
                                  IsHitTestVisible="False"/>

                            <!-- Content -->
                            <Grid Grid.Column="1" Margin="16,0">
                                <!-- Label -->
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding helpers:TextFieldAssist.Label}"
                                           Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="LabelScale" />
                                            <TranslateTransform x:Name="LabelTranslate" />
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Bottom"
                                                  Margin="0,0,0,8"
                                                  HorizontalAlignment="Left" />
                                
                                <!-- Toggle Button overlay to capture clicks -->
                                <ToggleButton x:Name="ToggleButton"
                                              Style="{StaticResource MaterialDesignComboBoxToggleButton}"
                                              Grid.ColumnSpan="2"
                                              Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press" />
                                
                            </Grid>
                        </Grid>
                        
                        <!-- Supporting Text -->
                        <TextBlock x:Name="SupportingText"
                                   Grid.Row="1"
                                   Text="{TemplateBinding helpers:TextFieldAssist.SupportingText}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                   Margin="16,4,16,0"
                                   Visibility="{TemplateBinding helpers:TextFieldAssist.SupportingText, Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Popup -->
                         <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource MdSysColor.SurfaceContainer}"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Margin="0,4,0,0">
                                     <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Has Items/Selected Item -->
                        <Trigger Property="HasItems" Value="false">
                            <Setter TargetName="Container" Property="Height" Value="56" />
                        </Trigger>

                        <!-- Floating Label Logic -->
                        <!-- Float label when focused -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-12" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="FocusIndicator" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!-- Float label when has selection (SelectedItem != null) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                <Condition Property="helpers:TextFieldAssist.HasSelection" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-12" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>

                        <!-- Reset label to center when no selection and not focused -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                                <Condition Property="helpers:TextFieldAssist.HasSelection" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                        <TranslateTransform Y="0" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                        </MultiTrigger>

                        <!-- DropDown Open State -->
                        <Trigger Property="IsDropDownOpen" Value="true">
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" CenterX="5" CenterY="2.5" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

     <!-- Outlined ComboBox -->
    <Style x:Key="MaterialDesignOutlinedComboBoxStyle" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.Outline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,16,16,16" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                     <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                         
                         <!-- Input Container -->
                         <Grid Grid.Row="0" Height="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Container"
                                    Grid.ColumnSpan="3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource MdSysShape.CornerExtraSmall}"
                                    SnapsToDevicePixels="True" />
                            
                            <!-- Trailing Icon (DropDown Arrow) -->
                            <Path Grid.Column="2" 
                                  x:Name="Arrow"
                                  Data="M7,10L12,15L17,10H7Z" 
                                  Fill="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"
                                  IsHitTestVisible="False"/>

                             <!-- Content -->
                            <Grid Grid.Column="1" Margin="16,0">
                                <!-- Label -->
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding helpers:TextFieldAssist.Label}"
                                           Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0,0"
                                           IsHitTestVisible="False"
                                           Background="{DynamicResource MdSysColor.Surface}">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="LabelScale" />
                                            <TranslateTransform x:Name="LabelTranslate" />
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                
                                <!-- Toggle Button overlay to capture clicks -->
                                <ToggleButton x:Name="ToggleButton"
                                              Style="{StaticResource MaterialDesignComboBoxToggleButton}"
                                              Grid.ColumnSpan="2"
                                              Focusable="false"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press" />
                            </Grid>
                        </Grid>
                         
                        <!-- Supporting Text -->
                        <TextBlock x:Name="SupportingText"
                                   Grid.Row="1"
                                   Text="{TemplateBinding helpers:TextFieldAssist.SupportingText}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                   Margin="16,4,16,0"
                                   Visibility="{TemplateBinding helpers:TextFieldAssist.SupportingText, Converter={StaticResource NullToVisibilityConverter}}" />
                         
                           <!-- Popup -->
                         <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource MdSysColor.SurfaceContainer}"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Margin="0,4,0,0">
                                     <Border.Effect>
                                        <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/>
                                    </Border.Effect>
                                    <ScrollViewer Margin="0,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                         
                     </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Floating Label Logic -->
                        <!-- Float label when focused -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-28" X="-4" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Label" Property="Padding" Value="4,0" />
                            <Setter TargetName="Container" Property="BorderBrush" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Container" Property="BorderThickness" Value="2" />
                        </MultiTrigger>

                        <!-- Float label when has selection -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                <Condition Property="helpers:TextFieldAssist.HasSelection" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-28" X="-4" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Label" Property="Padding" Value="4,0" />
                        </MultiTrigger>

                        <!-- DropDown Open State -->
                        <Trigger Property="IsDropDownOpen" Value="true">
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" CenterX="5" CenterY="2.5" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
