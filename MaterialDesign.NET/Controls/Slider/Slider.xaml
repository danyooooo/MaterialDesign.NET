<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers">

    <!-- Thumb Style with Motion Physics (VSM) -->
    <Style x:Key="MaterialDesignSliderThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                        <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                        <DoubleAnimation Storyboard.TargetName="Halo" Storyboard.TargetProperty="Opacity" To="0" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastEffects}" Value="1" KeySpline="{DynamicResource MdSysMotionSplineStandardFastEffects}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastEffects}" Value="1" KeySpline="{DynamicResource MdSysMotionSplineStandardFastEffects}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="Halo" Storyboard.TargetProperty="Opacity" To="0.12" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed"> <!-- Corresponds to Dragging mostly for Thumbs -->
                                    <Storyboard>
                                         <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastEffects}" Value="1" KeySpline="{DynamicResource MdSysMotionSplineStandardFastEffects}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastEffects}" Value="1" KeySpline="{DynamicResource MdSysMotionSplineStandardFastEffects}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimation Storyboard.TargetName="Halo" Storyboard.TargetProperty="Opacity" To="0.12" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                             <!-- Dragging state isn't a standard CommonState, but 'Pressed' often covers it for Thumb. 
                                  WPF Thumb has IsDragging property, but VSM usually maps IsPressed. 
                                  However, we can keep the Triggers for IsDragging if VSM doesn't catch it, 
                                  OR we can assume IsPressed=True during drag. 
                                  Let's rely on CommonStates.Pressed first, and add a Trigger for IsDragging to set VisualState if needed? 
                                  Actually, Triggers and VSM can conflict. 
                                  Let's assume IsDragging implies IsPressed for the Thumb (which captures mouse). -->
                        </VisualStateManager.VisualStateGroups>

                        <!-- Halo (Hover Effect) -->
                        <Ellipse x:Name="Halo"
                                 Width="40" Height="40"
                                 Fill="{DynamicResource MdSysColor.Primary}"
                                 Opacity="0"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="HaloScale" ScaleX="0" ScaleY="0" />
                            </Ellipse.RenderTransform>
                             <!-- Named parts for Storyboard targeting -->
                             <!-- We need to register names or target properties directly. 
                                  For transforms, it's easier to name the Transform object. -->
                        </Ellipse>
                        
                        <!-- Main Thumb -->
                        <Ellipse x:Name="ThumbVisual"
                                 Fill="{DynamicResource MdSysColor.Primary}"
                                 Effect="{DynamicResource MaterialDesignShadow1}" />
                    </Grid>
                     <!-- Triggers to map custom properties to VisualStates if Standard ones don't cover it -->
                     <ControlTemplate.Triggers>
                         <!-- Map IsDragging to Pressed state if not automatic -->
                         <Trigger Property="IsDragging" Value="True">
                             <Setter TargetName="ThumbVisual" Property="Effect" Value="{DynamicResource MaterialDesignShadow2}" />
                             <!-- We can't easily fire VSM from here without coding. 
                                  But usually Thumb.IsPressed is true when dragging. -->
                         </Trigger>
                     </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider Style (Keep existing structure, updated Thumb) -->
    <Style x:Key="MaterialDesignSlider" TargetType="{x:Type Slider}">
        <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Slider}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <!-- Track Container -->
                        <Grid Grid.Row="1" VerticalAlignment="Center" Height="40"> <!-- Touch target height -->
                            <Border Name="TrackBackground"
                                    Height="4"
                                    Background="{DynamicResource MdSysColor.SurfaceContainerHighest}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center" />
                            
                            <Canvas VerticalAlignment="Center" Height="4">
             	                <Rectangle x:Name="PART_SelectionRange"
                                           Height="4"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="2" RadiusY="2"
                                           Visibility="Hidden" />
                            </Canvas>

                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"
                                                        CornerRadius="2"
                                                        VerticalAlignment="Center" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{x:Null}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="Transparent" VerticalAlignment="Center" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Style="{DynamicResource MaterialDesignSliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        
                        <!-- Tick Bar (Discrete) -->
                        <TickBar x:Name="TopTick"
                                 Grid.Row="0"
                                 Placement="Top"
                                 Height="4"
                                 Visibility="Collapsed"
                                 Fill="{DynamicResource MdSysColor.OnSurfaceVariant}" />
                                 
                        <TickBar x:Name="BottomTick"
                                 Grid.Row="2"
                                 Placement="Bottom"
                                 Height="4"
                                 Visibility="Collapsed"
                                 Fill="{DynamicResource MdSysColor.OnSurfaceVariant}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="TickPlacement" Value="TopLeft">
                            <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                        </Trigger>
                         <Trigger Property="TickPlacement" Value="BottomRight">
                            <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                        </Trigger>
                         <Trigger Property="TickPlacement" Value="Both">
                            <Setter TargetName="TopTick" Property="Visibility" Value="Visible" />
                            <Setter TargetName="BottomTick" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
