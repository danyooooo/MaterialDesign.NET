<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls">

    <Style x:Key="MaterialDesignSwitchStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                         <!-- Hover State Logic (Opacity/Color changes) usually instant or fast fade -->
                                        <DoubleAnimation Storyboard.TargetName="HoverRipple"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                     <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverRipple"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.1" Duration="0:0:0.1" />
                                        <!-- Optionally scale thumb -->
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.38" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Unchecked">
                                    <Storyboard>
                                        <!-- Animate Thumb to Left -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastSpatial}" 
                                                                  Value="0" 
                                                                  KeySpline="{DynamicResource MdSysMotionSplineStandardFastSpatial}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <!-- Track Color -->
                                        <ColorAnimation Storyboard.TargetName="TrackBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource MdSysColor.SurfaceContainerHighest.Color}" 
                                                        Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}"/>
                                         <!-- Thumb Size/Color -->
                                         <ColorAnimation Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource MdSysColor.Outline.Color}" 
                                                        Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}"/>
                                          <DoubleAnimation Storyboard.TargetName="Thumb"
                                                          Storyboard.TargetProperty="Width"
                                                          To="16" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                          <DoubleAnimation Storyboard.TargetName="Thumb"
                                                          Storyboard.TargetProperty="Height"
                                                          To="16" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                          <!-- Icon Fade Out -->
                                          <DoubleAnimation Storyboard.TargetName="Icon"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <!-- Animate Thumb to Right (Width 52 - ThumbWidth approx? No, specify exact translate) -->
                                        <!-- Track Width 52. Thumb center to center. Local grid is 52 wide. -->
                                        <!-- Thumb container is 32x32. If we move container... -->
                                        <!-- Let's use TranslateTransform on the ThumbContainer or Thumb. -->
                                        <!-- Target X = 20 (52 - 32) -->
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X">
                                            <SplineDoubleKeyFrame KeyTime="{DynamicResource MdSysMotionTimeSpanStandardFastSpatial}" 
                                                                  Value="20" 
                                                                  KeySpline="{DynamicResource MdSysMotionSplineStandardFastSpatial}"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        
                                        <!-- Track Color -->
                                        <ColorAnimation Storyboard.TargetName="TrackBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource MdSysColor.Primary.Color}" 
                                                        Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}"/>
                                         <!-- Track Border Thickness -> 0 -->
                                          <ThicknessAnimation Storyboard.TargetName="TrackBorder"
                                                              Storyboard.TargetProperty="BorderThickness"
                                                              To="0" Duration="0" /> <!-- Instant or fast? -->

                                         <!-- Thumb Size/Color -->
                                         <ColorAnimation Storyboard.TargetName="ThumbBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource MdSysColor.OnPrimary.Color}" 
                                                        Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}"/>
                                          <DoubleAnimation Storyboard.TargetName="Thumb"
                                                          Storyboard.TargetProperty="Width"
                                                          To="24" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                          <DoubleAnimation Storyboard.TargetName="Thumb"
                                                          Storyboard.TargetProperty="Height"
                                                          To="24" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />

                                           <!-- Icon Fade In -->
                                          <DoubleAnimation Storyboard.TargetName="Icon"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="1" Duration="{DynamicResource MdSysMotionDurationStandardFastEffects}" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Grid x:Name="RootGrid">
                             <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Switch Container -->
                            <Grid Width="52" Height="32">
                                <!-- Track -->
                                <Border x:Name="Track" 
                                        CornerRadius="16" 
                                        Background="{DynamicResource MdSysColor.SurfaceContainerHighest}"
                                        BorderBrush="{DynamicResource MdSysColor.Outline}"
                                        BorderThickness="2">
                                    <Border x:Name="TrackBorder" Background="Transparent" CornerRadius="16" /> <!-- Extra layer for color animation if needed or just animate Track -->
                                </Border>
                                
                                <!-- Thumb Container -->
                                <Grid x:Name="ThumbContainer" HorizontalAlignment="Left" Width="32" Height="32">
                                    <Grid.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0" />
                                    </Grid.RenderTransform>

                                    <!-- Hover Ripple -->
                                    <local:Ripple x:Name="HoverRipple"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                  Feedback="{DynamicResource MdSysColor.Primary}"
                                                  Opacity="0" ClipToBounds="False" 
                                                  CornerRadius="16"/>
                                    
                                    <!-- Thumb -->
                                    <Border x:Name="Thumb" 
                                            Width="16" Height="16" 
                                            CornerRadius="16"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid>
                                            <Border x:Name="ThumbBorder" 
                                                    Background="{DynamicResource MdSysColor.Outline}" 
                                                    CornerRadius="16" />
                                            
                                            <Path x:Name="Icon" 
                                                  Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" 
                                                  Fill="{DynamicResource MdSysColor.OnPrimaryContainer}"
                                                  Width="12" Height="12" Stretch="Uniform"
                                                  Opacity="0"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
