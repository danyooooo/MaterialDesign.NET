<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <!-- 
        MD3 List Item Specs:
        - One-line: Height 56dp
        - Two-line: Height 72dp
        - Three-line: Height 88dp
        - Padding: 16dp horizontal (Start/End)
    -->

    <!-- Base Style (Single Line) -->
    <Style x:Key="MaterialDesignListBoxItem" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}"/>
        <Setter Property="FontSize" Value="16"/> <!-- BodyLarge -->
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Grid>
                        <!-- State Layer (Ripple/Hover/Selection) -->
                        <local:Ripple Feedback="{DynamicResource MdSysColor.OnSurface}"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"
                                      Padding="{TemplateBinding Padding}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                             <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Leading -->
                                    <ColumnDefinition Width="*" />    <!-- Content -->
                                    <ColumnDefinition Width="Auto" /> <!-- Trailing -->
                                </Grid.ColumnDefinitions>

                                <!-- Leading Content -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,16,0"
                                                  Visibility="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Headline -->
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>

                                <!-- Trailing Content -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <!-- Trailing Supporting Text -->
                                    <TextBlock Text="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                               Style="{DynamicResource MdSysTypescale.LabelSmall}"
                                               Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               Visibility="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                                    
                                    <!-- Trailing Content -->
                                    <ContentPresenter Content="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                      Visibility="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </local:Ripple>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SecondaryContainer}" />
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSecondaryContainer}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Two Line Style -->
    <Style x:Key="MaterialDesignTwoLineListBoxItem" TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource MaterialDesignListBoxItem}">
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Grid>
                         <local:Ripple Feedback="{DynamicResource MdSysColor.OnSurface}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Leading -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,0,16,0"
                                                  Visibility="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Content (Headline + Supporting Text) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <!-- Headline -->
                                    <ContentPresenter />
                                    <!-- Supporting Text -->
                                    <TextBlock Text="{Binding Path=(helpers:ListItemAssist.SupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                               Style="{DynamicResource MdSysTypescale.BodyMedium}"
                                               Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Path=(helpers:ListItemAssist.SupportingText), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>

                                <!-- Trailing -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="16,0,0,0">
                                   <TextBlock Text="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                               Style="{DynamicResource MdSysTypescale.LabelSmall}"
                                               Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                               VerticalAlignment="Top"
                                               Margin="0,0,8,0"
                                               Visibility="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                                    
                                    <ContentPresenter Content="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                      Visibility="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </local:Ripple>
                    </Grid>
                     <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SecondaryContainer}" />
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSecondaryContainer}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Three Line Style -->
    <Style x:Key="MaterialDesignThreeLineListBoxItem" TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource MaterialDesignTwoLineListBoxItem}">
        <Setter Property="MinHeight" Value="88"/>
        <Setter Property="Template">
             <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Grid>
                         <local:Ripple Feedback="{DynamicResource MdSysColor.OnSurface}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Leading -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,0,16,0"
                                                  Visibility="{Binding Path=(helpers:ListItemAssist.LeadingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <!-- Content (Headline + Supporting Text) -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <!-- Headline -->
                                    <ContentPresenter />
                                    <!-- Supporting Text (Up to 2 lines) -->
                                    <TextBlock Text="{Binding Path=(helpers:ListItemAssist.SupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                               Style="{DynamicResource MdSysTypescale.BodyMedium}"
                                               Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap"
                                               MaxHeight="40" 
                                               Visibility="{Binding Path=(helpers:ListItemAssist.SupportingText), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>

                                <!-- Trailing -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="16,0,0,0">
                                   <TextBlock Text="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                               Style="{DynamicResource MdSysTypescale.LabelSmall}"
                                               Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                               VerticalAlignment="Top"
                                               Margin="0,0,8,0"
                                               Visibility="{Binding Path=(helpers:ListItemAssist.TrailingSupportingText), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                                    
                                    <ContentPresenter Content="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}}"
                                                      Visibility="{Binding Path=(helpers:ListItemAssist.TrailingContent), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </local:Ripple>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SecondaryContainer}" />
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSecondaryContainer}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
