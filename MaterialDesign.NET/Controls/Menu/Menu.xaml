<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!-- MenuItem Style -->
    <Style x:Key="MaterialDesignMenuItem" TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="FontSize" Value="14" /> <!-- LabelLarge -->
        <Setter Property="FontWeight" Value="{DynamicResource MdRefTypeface.WeightMedium}" />
        <Setter Property="Height" Value="48" />
        <Setter Property="Padding" Value="12,0" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Grid>
                        <Border x:Name="BackgroundBorder" 
                                Background="{TemplateBinding Background}" />
                        <local:Ripple>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Arrow" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <ContentPresenter Grid.Column="0" 
                                                  ContentSource="Icon" 
                                                  VerticalAlignment="Center" 
                                                  Margin="0,0,12,0"
                                                  RecognizesAccessKey="True"/>

                                <!-- Header -->
                                <ContentPresenter Grid.Column="1" 
                                                  ContentSource="Header" 
                                                  VerticalAlignment="Center" 
                                                  RecognizesAccessKey="True"/>

                                <!-- Input Gesture Text (Shortcut) -->
                                <TextBlock Grid.Column="2" 
                                           Text="{TemplateBinding InputGestureText}" 
                                           VerticalAlignment="Center" 
                                           Margin="12,0,0,0"
                                           Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" 
                                           Style="{DynamicResource MdSysTypescale.LabelSmall}" />

                                <!-- Submenu Arrow (Right Arrow) -->
                                <Path Grid.Column="3" x:Name="Arrow"
                                      Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"
                                      Fill="{TemplateBinding Foreground}"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                                
                                <!-- Popup for Submenu -->
                                <Popup x:Name="Popup"
                                       Placement="Right"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       Focusable="False"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade">
                                            <Border Background="{DynamicResource MdSysColor.SurfaceContainer}"
                                                    BorderThickness="0"
                                                    CornerRadius="4"
                                                    Padding="0,8"
                                                    helpers:ShadowAssist.Elevation="Level2">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                            </Border>
                                </Popup>
                            </Grid>
                        </local:Ripple>
                    </Grid>
                    <ControlTemplate.Triggers>


                        <!-- Role: SubmenuHeader (Item with children) -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        
                        <!-- Role: SubmenuItem (Leaf item) -->
                        <Trigger Property="Role" Value="SubmenuItem">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        
                        <Trigger Property="IsHighlighted" Value="True">
                             <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Role: TopLevelHeader (e.g. File in MenuBar) -->
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Grid>
                                <Border x:Name="BackgroundBorder" 
                                        Background="{TemplateBinding Background}" />
                                <local:Ripple>
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" Margin="24,0"/>
                                </local:Ripple>
                                <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" Focusable="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="4" Padding="0,8" helpers:ShadowAssist.Elevation="Level2">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            
            <!-- Role: TopLevelItem (e.g. Action in MenuBar without submenu) -->
            <Trigger Property="Role" Value="TopLevelItem">
                    <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type MenuItem}">
                            <Grid>
                                <Border x:Name="BackgroundBorder" 
                                        Background="{TemplateBinding Background}" />
                                <local:Ripple>
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" Margin="24,0"/>
                                </local:Ripple>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ContextMenu Style -->
    <Style x:Key="MaterialDesignContextMenu" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainer}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HasDropShadow" Value="True" /> <!-- WPF Built-in shadow, we might want to disable and use our own Elevation -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="4"
                            Padding="0,8"
                            helpers:ShadowAssist.Elevation="Level2">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Style (MenuBar) -->
    <Style x:Key="MaterialDesignMenu" TargetType="{x:Type Menu}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerLow}" /> <!-- MenuBar usually matches surface or slightly distinctive -->
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Menu}">
                    <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="0">
                        <StackPanel ClipToBounds="True" Orientation="Horizontal" IsItemsHost="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



</ResourceDictionary>
