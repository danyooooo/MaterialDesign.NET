<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <!-- Plain ToolTip -->
    <Style x:Key="MaterialDesignToolTip" TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.InverseSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.InverseOnSurface}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="12" /> <!-- BodySmall -->
        <Setter Property="HorizontalOffset" Value="0" />
        <Setter Property="VerticalOffset" Value="0" />
        <Setter Property="Placement" Value="MousePoint" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            Effect="{DynamicResource MaterialDesignShadow0}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Rich ToolTip -->
    <Style x:Key="MaterialDesignRichToolTip" TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainer}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurfaceVariant}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="FontSize" Value="14" /> <!-- BodyMedium -->
        <Setter Property="Placement" Value="MousePoint" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}"
                            Effect="{DynamicResource MaterialDesignShadow2}">
                        <StackPanel>
                            <!-- Use Tag for Title if provided, simple convention -->
                            <TextBlock Text="{TemplateBinding Tag}" 
                                       Style="{DynamicResource MdSysTypescale.TitleSmall}" 
                                       Foreground="{DynamicResource MdSysColor.OnSurface}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                            
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
