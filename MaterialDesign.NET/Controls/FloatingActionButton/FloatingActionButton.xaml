<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers">

    <!-- Base FAB Style -->
    <Style x:Key="MaterialDesignBaseFABStyle" TargetType="Button">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="{DynamicResource MdSysColor.PrimaryContainer}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnPrimaryContainer}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource MdSysShape.CornerLarge}">
                            <local:Ripple CornerRadius="{DynamicResource MdSysShape.CornerLarge}"
                                          Feedback="{TemplateBinding Foreground}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </local:Ripple>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level4" />
                             <!-- Note: State Layer overlay is handled by Ripple usually, but strictly speaking we might need a color overlay here too. 
                                  For simplicity relying on Elevation change + Ripple hover effect if available. -->
                        </Trigger>
                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
                        </Trigger>
                        <!-- Disabled State -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary FAB (Default) -->
    <Style x:Key="MaterialDesignFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignBaseFABStyle}">
        <!-- Default properties are already PrimaryContainer/OnPrimaryContainer -->
    </Style>

    <!-- Surface FAB -->
    <Style x:Key="MaterialDesignSurfaceFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignBaseFABStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHigh}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
    </Style>

    <!-- Secondary FAB -->
    <Style x:Key="MaterialDesignSecondaryFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignBaseFABStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SecondaryContainer}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSecondaryContainer}" />
    </Style>

    <!-- Tertiary FAB -->
    <Style x:Key="MaterialDesignTertiaryFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignBaseFABStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.TertiaryContainer}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnTertiaryContainer}" />
    </Style>

    <!-- Small FAB -->
    <Style x:Key="MaterialDesignSmallFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFABStyle}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <!-- Small FAB uses CornerMedium (12dp) usually? MD3 spec says container-shape: 12px. -->
         <Setter Property="Template">
            <Setter.Value>
                 <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource MdSysShape.CornerMedium}">
                            <local:Ripple CornerRadius="{DynamicResource MdSysShape.CornerMedium}"
                                          Feedback="{TemplateBinding Foreground}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </local:Ripple>
                        </Border>
                    </Grid>
                     <!-- Triggers same as Base -->
                     <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Large FAB -->
    <Style x:Key="MaterialDesignLargeFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFABStyle}">
        <Setter Property="Width" Value="96" />
        <Setter Property="Height" Value="96" />
        <!-- Large FAB uses CornerExtraLarge (28dp). -->
         <Setter Property="Template">
            <Setter.Value>
                 <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource MdSysShape.CornerExtraLarge}">
                            <local:Ripple CornerRadius="{DynamicResource MdSysShape.CornerExtraLarge}"
                                          Feedback="{TemplateBinding Foreground}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </local:Ripple>
                        </Border>
                    </Grid>
                     <!-- Triggers same as Base -->
                     <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Extended FAB -->
    <Style x:Key="MaterialDesignExtendedFABStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignBaseFABStyle}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Padding" Value="16,0,24,0" /> <!-- Icon padding 16, Text padding 24 -->
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource MdSysShape.CornerLarge}">
                            <local:Ripple CornerRadius="{DynamicResource MdSysShape.CornerLarge}"
                                          Feedback="{TemplateBinding Foreground}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}">
                                    <!-- Icon (from Content) -->
                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                      RecognizesAccessKey="True" />
                                    <!-- Text Label (from Tag or separate property) -->
                                    <TextBlock x:Name="LabelText"
                                               Text="{TemplateBinding Tag}"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               Style="{DynamicResource MdSysTypescale.LabelLarge}" />
                                </StackPanel>
                            </local:Ripple>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level4" />
                        </Trigger>
                        <!-- Pressed State -->
                        <Trigger Property="IsPressed" Value="True">
                             <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
                        </Trigger>
                        <!-- Disabled State -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                        <!-- Hide text if Tag is empty -->
                        <Trigger Property="Tag" Value="">
                            <Setter TargetName="LabelText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
