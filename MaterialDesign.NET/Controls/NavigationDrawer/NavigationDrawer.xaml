<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers">

    <!-- Navigation Drawer Item Style -->
    <Style x:Key="MaterialDesignNavigationDrawerItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="12,0,12,4" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Grid x:Name="RootGrid" Background="Transparent">
                        <!-- Active Indicator (Pill Shape) -->
                        <Border x:Name="Indicator" 
                                Background="Transparent" 
                                CornerRadius="28" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch" />
                        
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Hover State -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource MdSysColor.OnSurfaceVariant}" />
                            <Setter TargetName="Indicator" Property="Opacity" Value="0.08" />
                        </Trigger>
                        <!-- Selected State -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource MdSysColor.SecondaryContainer}" />
                            <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSecondaryContainer}" />
                        </Trigger>
                        <!-- Unselected/Normal State -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurfaceVariant}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Navigation Drawer Style (Standard/Permanent) -->
    <Style x:Key="MaterialDesignNavigationDrawerStyle" TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerLow}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,12" />
        <Setter Property="Width" Value="360" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ItemContainerStyle" Value="{DynamicResource MaterialDesignNavigationDrawerItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBox}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding Border.CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer Focusable="False" Padding="{TemplateBinding Padding}">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modal Navigation Drawer Style (Rounded Corners) -->
    <Style x:Key="MaterialDesignModalNavigationDrawerStyle" TargetType="{x:Type ListBox}" BasedOn="{StaticResource MaterialDesignNavigationDrawerStyle}">
        <Setter Property="Border.CornerRadius" Value="{DynamicResource MdSysShape.CornerLargeEnd}" /> <!-- 0,16,16,0 -->
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level1" />
    </Style>

</ResourceDictionary>
