<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <!-- Filled TextField (Default) -->
    <Style x:Key="MaterialDesignFilledTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurfaceVariant}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" /> <!-- Active Indicator line -->
        <Setter Property="Padding" Value="16,24,16,8" /> <!-- Top padding for floating label space -->
        <Setter Property="VerticalContentAlignment" Value="Bottom" />
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="CaretBrush" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Input Container -->
                        <Grid Grid.Row="0" Height="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Container"
                                    Grid.ColumnSpan="3"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4,4,0,0"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True" />
                            
                            <!-- Focus Indicator -->
                            <Border x:Name="FocusIndicator"
                                    Grid.ColumnSpan="3"
                                    Background="{DynamicResource MdSysColor.Primary}"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Visibility="Collapsed" />

                            <!-- Leading Icon -->
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding helpers:TextFieldAssist.LeadingIcon}"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0" 
                                              TextElement.Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>

                            <Grid Grid.Column="1" Margin="16,0">
                                <!-- Label -->
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding helpers:TextFieldAssist.Label}"
                                           Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="LabelScale" />
                                            <TranslateTransform x:Name="LabelTranslate" />
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                </TextBlock>

                                <!-- Content -->
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0,24,0,8"
                                              VerticalAlignment="Top"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>

                            <!-- Trailing Icon -->
                            <ContentPresenter Grid.Column="2"
                                              Content="{TemplateBinding helpers:TextFieldAssist.TrailingIcon}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0" 
                                              TextElement.Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                        </Grid>
                        
                        <!-- Supporting Text -->
                        <TextBlock x:Name="SupportingText"
                                   Grid.Row="1"
                                   Text="{TemplateBinding helpers:TextFieldAssist.SupportingText}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                   Margin="16,4,16,0"
                                   Visibility="{TemplateBinding helpers:TextFieldAssist.SupportingText, Converter={StaticResource NullToVisibilityConverter}}" />
                        
                        <!-- Error Text -->
                        <TextBlock x:Name="ErrorText"
                                   Grid.Row="1"
                                   Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(Validation.Errors)[0].ErrorContent}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.Error}"
                                   Margin="16,4,16,0"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Floating Label Trigger Logics -->
                        <Trigger Property="helpers:TextFieldAssist.HasText" Value="True">
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-12" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                             <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-12" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="FocusIndicator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- Error State -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Error}" />
                            <Setter TargetName="FocusIndicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusIndicator" Property="Background" Value="{DynamicResource MdSysColor.Error}" />
                            <Setter TargetName="SupportingText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ErrorText" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Outlined TextField -->
    <Style x:Key="MaterialDesignOutlinedTextBoxStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.Outline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,16,16,16" />
        <Setter Property="FontFamily" Value="{DynamicResource MdRefTypeface.Brand}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="CaretBrush" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Input Container -->
                        <Grid Grid.Row="0" Height="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Container"
                                    Grid.ColumnSpan="3"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource MdSysShape.CornerExtraSmall}"
                                    SnapsToDevicePixels="True" />

                            <!-- Leading Icon -->
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding helpers:TextFieldAssist.LeadingIcon}"
                                              VerticalAlignment="Center"
                                              Margin="12,0,0,0" 
                                              TextElement.Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>

                            <Grid Grid.Column="1" Margin="16,0">
                                <!-- Label -->
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding helpers:TextFieldAssist.Label}"
                                           Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0,0"
                                           IsHitTestVisible="False"
                                           Background="{DynamicResource MdSysColor.Surface}">
                                    <TextBlock.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="LabelScale" />
                                            <TranslateTransform x:Name="LabelTranslate" />
                                        </TransformGroup>
                                    </TextBlock.RenderTransform>
                                </TextBlock>

                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Grid>

                            <!-- Trailing Icon -->
                            <ContentPresenter Grid.Column="2"
                                              Content="{TemplateBinding helpers:TextFieldAssist.TrailingIcon}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0" 
                                              TextElement.Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                        </Grid>

                        <!-- Supporting Text -->
                        <TextBlock x:Name="SupportingText"
                                   Grid.Row="1"
                                   Text="{TemplateBinding helpers:TextFieldAssist.SupportingText}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"
                                   Margin="16,4,16,0"
                                   Visibility="{TemplateBinding helpers:TextFieldAssist.SupportingText, Converter={StaticResource NullToVisibilityConverter}}" />
                        
                        <!-- Error Text -->
                        <TextBlock x:Name="ErrorText"
                                   Grid.Row="1"
                                   Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(Validation.Errors)[0].ErrorContent}"
                                   Style="{DynamicResource MdSysTypescale.BodySmall}"
                                   Foreground="{DynamicResource MdSysColor.Error}"
                                   Margin="16,4,16,0"
                                   Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                         <!-- Has Text -->
                        <Trigger Property="helpers:TextFieldAssist.HasText" Value="True">
                             <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-28" X="-4" /> <!-- Move up to border line -->
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                             <Setter TargetName="Label" Property="Background" Value="{DynamicResource MdSysColor.Surface}" />
                             <Setter TargetName="Label" Property="Padding" Value="4,0" /> 
                        </Trigger>
                        
                        <!-- Focused -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Label" Property="RenderTransform">
                                <Setter.Value>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                        <TranslateTransform Y="-28" X="-4" />
                                    </TransformGroup>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Label" Property="Background" Value="{DynamicResource MdSysColor.Surface}" />
                            <Setter TargetName="Label" Property="Padding" Value="4,0" />
                            <Setter TargetName="Container" Property="BorderBrush" Value="{DynamicResource MdSysColor.Primary}" />
                            <Setter TargetName="Container" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <!-- Error State -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource MdSysColor.Error}" />
                            <Setter TargetName="Container" Property="BorderBrush" Value="{DynamicResource MdSysColor.Error}" />
                            <Setter TargetName="Container" Property="BorderThickness" Value="2" />
                            <Setter TargetName="SupportingText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ErrorText" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
