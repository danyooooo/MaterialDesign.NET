<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <Style x:Key="MaterialDesignSnackbarStyle" TargetType="{x:Type local:Snackbar}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.InverseSurface}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.InverseOnSurface}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Margin" Value="24" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Snackbar}">
                    <Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="Active">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.3" />
                                        <ThicknessAnimation Storyboard.TargetName="RootBorder"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="0,0,0,0" Duration="0:0:0.3" DecelerationRatio="0.9" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Inactive">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.3" />
                                        <ThicknessAnimation Storyboard.TargetName="RootBorder"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="0,20,0,-20" Duration="0:0:0.3" AccelerationRatio="0.9" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource MdSysShape.CornerExtraSmall}"
                                Effect="{DynamicResource MaterialDesignShadow3}"
                                Opacity="0"
                                Margin="0,20,0,-20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Message -->
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding Message}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />

                                <!-- Action Button -->
                                <Button Grid.Column="1"
                                        Style="{DynamicResource MaterialDesignTextButtonStyle}"
                                        Content="{TemplateBinding ActionContent}"
                                        Command="{TemplateBinding ActionCommand}"
                                        CommandParameter="{TemplateBinding ActionCommandParameter}"
                                        Foreground="{DynamicResource MdSysColor.InversePrimary}"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding ActionContent, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource NullToVisibilityConverter}}" />
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsActive" Value="True">
                             <Setter TargetName="RootBorder" Property="Opacity" Value="1" />
                             <Setter TargetName="RootBorder" Property="Margin" Value="0" />
                        </Trigger>
                        <!-- Fallback for no VisualStateManager in simplified implementation -->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Snackbar}" BasedOn="{StaticResource MaterialDesignSnackbarStyle}" />

</ResourceDictionary>
