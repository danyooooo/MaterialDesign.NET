<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:MaterialDesign.NET.Converters">

    <converters:CircularProgressConverter x:Key="CircularProgressConverter" />

    <!-- Linear Progress Bar -->
    <Style x:Key="MaterialDesignLinearProgressBar" TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid x:Name="TemplateRoot">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2" /> <!-- Track -->
                        <Border x:Name="PART_Track" />
                        <Border x:Name="PART_Indicator" 
                                Background="{TemplateBinding Foreground}" 
                                CornerRadius="2" 
                                HorizontalAlignment="Left" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Indeterminate State -->
                        <Trigger Property="IsIndeterminate" Value="True">
                             <!-- Standard WPF Indeterminate animation handles PART_Indicator automatically if setup correctly, 
                                  but mostly expects specific naming or visual state manager. 
                                  For simple styling, the default localized logic might work if PART_Indicator is present. 
                                  However, often easier to swap to a custom indeterminate visual. -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Circular Progress Bar -->
    <Style x:Key="MaterialDesignCircularProgressBar" TargetType="{x:Type ProgressBar}">
        <Setter Property="Height" Value="48" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.Primary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Viewbox>
                        <Grid Width="24" Height="24"> <!-- Internal Coordinate System -->
                            <!-- Rotator for Indeterminate -->
                            <Grid x:Name="Rotator" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform Angle="0" />
                                </Grid.RenderTransform>

                                <!-- Track (Optional, usually implied or secondary color) 
                                     MD3 often doesn't show a full track for circular, just the spinner. 
                                     If needed: <Ellipse Width="20" Height="20" Stroke="{TemplateBinding Background}" StrokeThickness="2.5" /> 
                                -->

                                <!-- Determinate Indicator -->
                                <Ellipse x:Name="DeterminateIndicator"
                                         Width="18" Height="18"
                                         Stroke="{TemplateBinding Foreground}"
                                         StrokeThickness="2.5"
                                         StrokeDashCap="Round"
                                         RenderTransformOrigin="0.5,0.5">
                                     <!-- Circumference = 18 * PI = 56.548 
                                          StrokeThickness = 2.5
                                          FullDashArray = 56.548 / 2.5 = 22.619
                                     -->
                                     <Ellipse.RenderTransform>
                                         <RotateTransform Angle="-90" /> <!-- Start at top -->
                                     </Ellipse.RenderTransform>
                                     <Ellipse.StrokeDashArray>
                                         <MultiBinding Converter="{StaticResource CircularProgressConverter}" ConverterParameter="22.619">
                                             <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                             <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}" />
                                             <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                         </MultiBinding>
                                     </Ellipse.StrokeDashArray>
                                </Ellipse>

                                <!-- Indeterminate Indicator -->
                                <Ellipse x:Name="IndeterminateIndicator"
                                         Width="18" Height="18"
                                         Stroke="{TemplateBinding Foreground}"
                                         StrokeThickness="2.5"
                                         StrokeDashCap="Round"
                                         StrokeDashArray="18, 22.619" 
                                         Visibility="Collapsed"
                                         RenderTransformOrigin="0.5, 0.5">
                                      <!-- Fixed Dash for now, or animated -->
                                </Ellipse>
                            </Grid>
                        </Grid>
                    </Viewbox>
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="SpinStoryboard" RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="Rotator"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0" To="360" Duration="0:0:1.333" /> <!-- 1333ms per MD3 spec -->
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <!-- Indeterminate Logic -->
                        <Trigger Property="IsIndeterminate" Value="True">
                             <Setter TargetName="DeterminateIndicator" Property="Visibility" Value="Collapsed" />
                             <Setter TargetName="IndeterminateIndicator" Property="Visibility" Value="Visible" />
                             <Trigger.EnterActions>
                                 <BeginStoryboard Storyboard="{StaticResource SpinStoryboard}" x:Name="SpinData" />
                             </Trigger.EnterActions>
                             <Trigger.ExitActions>
                                 <StopStoryboard BeginStoryboardName="SpinData" />
                             </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
