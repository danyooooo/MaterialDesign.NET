<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers">

    <Style x:Key="MaterialDesignCardStyle" TargetType="ContentControl">
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerLow}" />
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource MdSysShape.CornerMedium}">
                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Elevated Card -->
    <Style x:Key="MaterialDesignElevatedCardStyle" TargetType="ContentControl" BasedOn="{StaticResource MaterialDesignCardStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerLow}" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level1" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="helpers:ShadowAssist.Elevation" Value="Level2" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Filled Card -->
    <Style x:Key="MaterialDesignFilledCardStyle" TargetType="ContentControl" BasedOn="{StaticResource MaterialDesignCardStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="helpers:ShadowAssist.Elevation" Value="Level1" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Outlined Card -->
    <Style x:Key="MaterialDesignOutlinedCardStyle" TargetType="ContentControl" BasedOn="{StaticResource MaterialDesignCardStyle}">
        <Setter Property="Background" Value="{DynamicResource MdSysColor.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.OutlineVariant}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="helpers:ShadowAssist.Elevation" Value="Level0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="helpers:ShadowAssist.Elevation" Value="Level1" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
