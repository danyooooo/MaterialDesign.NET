<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:MaterialDesign.NET.Controls">

    <Style x:Key="MaterialDesignRadioButtonStyle" TargetType="{x:Type RadioButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Foreground" Value="{DynamicResource MdSysColor.OnSurface}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                         <!-- Ripple Container -->
                        <Grid Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center">
                             <local:Ripple HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                             ClipToBounds="False"
                                             Feedback="{DynamicResource MdSysColor.Primary}"
                                             Opacity="0.1" 
                                             CornerRadius="20"/>

                            <!-- Radio Outer Circle -->
                            <Border x:Name="RadioBorder" 
                                    Width="20" Height="20" 
                                    CornerRadius="10"
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="Transparent"
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center">
                                 <!-- Radio Inner Circle (Dot) -->
                                <Border x:Name="RadioDot"
                                        Width="10" Height="10"
                                        CornerRadius="5"
                                        Background="{DynamicResource MdSysColor.Primary}"
                                        HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        Opacity="0"/>
                            </Border>
                        </Grid>

                        <ContentPresenter x:Name="contentPresenter" 
                                          Grid.Column="1" 
                                          Focusable="False" 
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                          Margin="{TemplateBinding Padding}" 
                                          RecognizesAccessKey="True" 
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" 
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Checked State -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{DynamicResource MdSysColor.Primary}"/>
                             <Setter TargetName="RadioDot" Property="Opacity" Value="1"/>
                        </Trigger>
                        
                        <!-- MouseOver Unchecked -->
                         <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                             <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurface}"/>
                             <Setter TargetName="RadioBorder" Property="Background" Value="{DynamicResource MdSysColor.SurfaceContainerHighest}"/>
                        </MultiTrigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38"/>
                             <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurface}"/>
                        </Trigger>
                        
                         <!-- Disabled Checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False"/>
                                <Condition Property="IsChecked" Value="True"/>
                            </MultiTrigger.Conditions>
                             <Setter TargetName="RadioDot" Property="Background" Value="{DynamicResource MdSysColor.OnSurface}"/>
                             <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{DynamicResource MdSysColor.OnSurface}"/>
                        </MultiTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
