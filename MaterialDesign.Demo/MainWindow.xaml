<Window x:Class="MaterialDesign.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:domain="clr-namespace:MaterialDesign.Demo.Domain"
        xmlns:controls="clr-namespace:MaterialDesign.NET.Controls;assembly=MaterialDesign.NET"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Material Design 3 Demo" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{DynamicResource MdSysColor.Surface}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type domain:ConfirmationDialogViewModel}">
            <StackPanel MinWidth="280">
                <controls:SymbolIcon Symbol="chat_bubble" Variant="Outlined" Filled="True" Width="32" Height="32" HorizontalAlignment="Center" Margin="0,0,0,16" Foreground="{DynamicResource MdSysColor.Primary}"/>
                <TextBlock Text="{Binding Title}" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding Message}" Style="{DynamicResource MdSysTypescale.BodyMedium}" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,0,0,24" TextAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{DynamicResource MaterialDesignTextButtonStyle}" Command="{Binding DataContext.CloseDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,8,0"/>
                    <Button Content="Confirm" Command="{Binding DataContext.CloseDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type domain:SimpleDialogContent}">
             <StackPanel MinWidth="200">
                <TextBlock Text="{Binding Header}" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding Message}" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="0,0,0,24"/>
                <Button Content="Close" HorizontalAlignment="Right" Command="{Binding DataContext.CloseDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
             </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <controls:DialogHost IsOpen="{Binding IsDialogOpen}" DialogContent="{Binding DialogContent}">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation Drawer -->
        <Border Grid.Column="0" Background="{DynamicResource MdSysColor.SurfaceContainer}" BorderBrush="{DynamicResource MdSysColor.OutlineVariant}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="24,24,24,24">
                     <TextBlock Text="Material" FontWeight="Bold" FontSize="18" Foreground="{DynamicResource MdSysColor.Primary}" />
                     <TextBlock Text="Design 3" FontSize="18" Foreground="{DynamicResource MdSysColor.OnSurface}" />
                </StackPanel>

                 <!-- Drawer List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Style="{DynamicResource MaterialDesignNavigationDrawerStyle}"
                         Padding="12"
                         ScrollViewer.CanContentScroll="False"
                         ScrollViewer.PanningMode="VerticalOnly">
                    <ListBox.ItemContainerStyle>
                        <!-- Inline style to ensure drawer look for items -->
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignNavigationDrawerItemStyle}">
                             <Setter Property="Margin" Value="0,0,0,0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type domain:NavigationItem}">
                             <StackPanel Orientation="Horizontal">
                                 <controls:PackIcon Kind="{Binding Symbol}" Margin="0,0,12,0" />
                                 <TextBlock Text="{Binding Name}" Style="{DynamicResource MdSysTypescale.LabelLarge}" VerticalAlignment="Center"/>
                             </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Padding="0">
            <ContentControl Content="{Binding CurrentPage}" />
        </Border>
        </Grid>
    </controls:DialogHost>
</Window>
