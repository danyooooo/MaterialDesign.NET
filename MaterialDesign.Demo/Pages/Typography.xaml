<UserControl x:Class="MaterialDesign.Demo.Pages.Typography"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Typography" Style="{DynamicResource MdSysTypescale.DisplaySmall}" Margin="0,0,0,8" />
            <TextBlock Text="Use typography to present your design and content as clearly and efficiently as possible." Style="{DynamicResource MdSysTypescale.BodyLarge}" Margin="0,0,0,32" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" TextWrapping="Wrap" />

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Display" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Display Large" Style="{DynamicResource MdSysTypescale.DisplayLarge}" Margin="0,0,0,8" />
                        <TextBlock Text="Display Medium" Style="{DynamicResource MdSysTypescale.DisplayMedium}" Margin="0,0,0,8" />
                        <TextBlock Text="Display Small" Style="{DynamicResource MdSysTypescale.DisplaySmall}" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Headline" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Headline Large" Style="{DynamicResource MdSysTypescale.HeadlineLarge}" Margin="0,0,0,8" />
                        <TextBlock Text="Headline Medium" Style="{DynamicResource MdSysTypescale.HeadlineMedium}" Margin="0,0,0,8" />
                        <TextBlock Text="Headline Small" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Title" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Title Large" Style="{DynamicResource MdSysTypescale.TitleLarge}" Margin="0,0,0,8" />
                        <TextBlock Text="Title Medium" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8" />
                        <TextBlock Text="Title Small" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Body" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Body Large" Style="{DynamicResource MdSysTypescale.BodyLarge}" Margin="0,0,0,8" />
                        <TextBlock Text="Body Medium" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="0,0,0,8" />
                        <TextBlock Text="Body Small" Style="{DynamicResource MdSysTypescale.BodySmall}" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Label" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Label Large" Style="{DynamicResource MdSysTypescale.LabelLarge}" Margin="0,0,0,8" />
                        <TextBlock Text="Label Medium" Style="{DynamicResource MdSysTypescale.LabelMedium}" Margin="0,0,0,8" />
                        <TextBlock Text="Label Small" Style="{DynamicResource MdSysTypescale.LabelSmall}" Margin="0,0,0,8" />
                    </StackPanel>
                </Border>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
