<UserControl x:Class="MaterialDesign.Demo.Pages.Progress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers;assembly=MaterialDesign.NET"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer>
        <StackPanel Margin="32">
            <!-- Header -->
            <TextBlock Text="Progress Indicators" Style="{DynamicResource MdSysTypescale.DisplayMedium}" Margin="0,0,0,8" />
            <TextBlock Text="Progress indicators express an unspecified wait time or display the length of a process." 
                       Style="{DynamicResource MdSysTypescale.BodyLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" Margin="0,0,0,32" />

            <!-- Control Box -->
            <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24" Margin="0,0,0,32">
                <StackPanel>
                     <TextBlock Text="Controls" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,16" />
                     <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                         <TextBlock Text="Value: " VerticalAlignment="Center" Width="60"/>
                         <TextBlock Text="{Binding ElementName=ValueSlider, Path=Value, StringFormat=N0}" VerticalAlignment="Center" Width="40" FontWeight="Bold"/>
                         <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="50" Width="200" TickFrequency="1" IsSnapToTickEnabled="True"/>
                     </StackPanel>
                </StackPanel>
            </Border>

            <!-- Circular Progress -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Circular Progress" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <WrapPanel>
                        <!-- Indeterminate -->
                        <StackPanel Margin="0,0,48,24">
                            <TextBlock Text="Indeterminate" Style="{DynamicResource MdSysTypescale.LabelLarge}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                            <ProgressBar Style="{DynamicResource MaterialDesignCircularProgressBar}" 
                                         IsIndeterminate="True" 
                                         HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Determinate -->
                        <StackPanel Margin="0,0,48,24">
                            <TextBlock Text="Determinate" Style="{DynamicResource MdSysTypescale.LabelLarge}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                            <ProgressBar Style="{DynamicResource MaterialDesignCircularProgressBar}" 
                                         Value="{Binding ElementName=ValueSlider, Path=Value}" 
                                         HorizontalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </Border>
            </StackPanel>

            <!-- Linear Progress -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Linear Progress" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                     <StackPanel>
                        <!-- Indeterminate -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Indeterminate" Style="{DynamicResource MdSysTypescale.LabelLarge}" Margin="0,0,0,8"/>
                            <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" 
                                         IsIndeterminate="True" />
                        </StackPanel>

                        <!-- Determinate -->
                        <StackPanel Margin="0,0,0,24">
                            <TextBlock Text="Determinate" Style="{DynamicResource MdSysTypescale.LabelLarge}" Margin="0,0,0,8"/>
                            <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" 
                                         Value="{Binding ElementName=ValueSlider, Path=Value}" />
                        </StackPanel>
                     </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
