<UserControl x:Class="MaterialDesign.Demo.Pages.VideoStreamingExample"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:MaterialDesign.NET.Controls;assembly=MaterialDesign.NET"
             xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers;assembly=MaterialDesign.NET"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400">
    <Grid Background="{DynamicResource MdSysColor.Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top App Bar -->
        <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="16,12" BorderBrush="{DynamicResource MdSysColor.OutlineVariant}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"><TextBlock Text="StreamFlix" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Grid.Column="1" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="24" Padding="16,8" Margin="32,0" MaxWidth="600" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions><TextBox Grid.Column="1" Text="Search movies, TV shows..." Style="{DynamicResource MaterialDesignOutlinedTextBoxStyle}" BorderThickness="0" Background="Transparent" FontSize="14" Margin="8,0"/>
                        <Button Grid.Column="2" Style="{DynamicResource MaterialDesignFilledButtonStyle}" Padding="16,8"></Button>
                    </Grid>
                </Border>

                <!-- Right Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" ToolTip="Notifications">
                        <Grid><controls:Badge BadgeContent="3" Style="{DynamicResource MaterialDesignBadgeStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                        </Grid>
                    </Button>
                    <Border Width="40" Height="40" CornerRadius="20" Background="{DynamicResource MdSysColor.PrimaryContainer}" Margin="8,0">
                        <TextBlock Text="JD" Style="{DynamicResource MdSysTypescale.TitleMedium}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <!-- Hero - Featured Content -->
                <Border CornerRadius="{DynamicResource MdSysShape.CornerLarge}" Padding="0" Margin="0,0,0,32" Height="400">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1a1a2e" Offset="0"/>
                            <GradientStop Color="#16213e" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="400"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="48,0,0,0">
                            <Border Background="{DynamicResource MdSysColor.Primary}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" Margin="0,0,0,16">
                                <TextBlock Text="NEW RELEASE" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnPrimary}"/>
                            </Border>
                            <TextBlock Text="Dune: Part Two" Style="{DynamicResource MdSysTypescale.DisplayLarge}" Foreground="White" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="White" Opacity="0.9" CornerRadius="2" Padding="4,2" Margin="0,0,8,0">
                                    <TextBlock Text="PG-13" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="Black"/>
                                </Border>
                                <TextBlock Text="2h 46m" Style="{DynamicResource MdSysTypescale.BodyLarge}" Foreground="White" Opacity="0.8" Margin="0,0,8,0"/>
                                <TextBlock Text="Sci-Fi • Adventure" Style="{DynamicResource MdSysTypescale.BodyLarge}" Foreground="White" Opacity="0.8"/>
                            </StackPanel>
                            <TextBlock Text="Paul Atreides unites with Chani and the Fremen while on a warpath of revenge against the conspirators who destroyed his family." Style="{DynamicResource MdSysTypescale.BodyLarge}" Foreground="White" Opacity="0.8" TextWrapping="Wrap" MaxWidth="600" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}" Content="Play Now" Width="140" Margin="0,0,12,0">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{DynamicResource MaterialDesignTonalButtonStyle}" Content="More Info" Width="140">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"><TextBlock Text="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Poster -->
                        <Border Grid.Column="1" Width="280" Height="400" CornerRadius="8" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" Margin="0,0,48,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="Movie Poster" Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Categories Chips -->
                <StackPanel Margin="0,0,0,24">
                    <WrapPanel>
                        <ToggleButton Content="For You" Style="{DynamicResource MaterialDesignFilterChipStyle}" IsChecked="True" Margin="0,0,8,8"/>
                        <ToggleButton Content="Movies" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="TV Shows" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="Action" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="Comedy" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="Drama" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="Documentary" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                        <ToggleButton Content="Horror" Style="{DynamicResource MaterialDesignFilterChipStyle}" Margin="0,0,8,8"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Continue Watching -->
                <StackPanel Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Continue Watching" Style="{DynamicResource MdSysTypescale.TitleLarge}"/>
                        <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="See All" Margin="12,0,0,0"/>
                    </StackPanel>
                    
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <!-- Video Card 1 -->
                            <Border Width="280" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="156"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0">
                                        <Grid><Border Background="#80000000" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                <TextBlock Text="45:32 / 52:14" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="White"/>
                                            </Border>
                                            <!-- Progress bar -->
                                            <Border Height="4" Background="#40ffffff" VerticalAlignment="Bottom">
                                                <Border Width="175" Background="{DynamicResource MdSysColor.Primary}" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="16">
                                        <TextBlock Text="Stranger Things" Style="{DynamicResource MdSysTypescale.TitleMedium}"/>
                                        <TextBlock Text="S4 E5 • The Nina Project" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Video Card 2 -->
                            <Border Width="280" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="156"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0">
                                        <Grid><Border Background="#80000000" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                <TextBlock Text="22:15 / 28:40" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="White"/>
                                            </Border>
                                            <Border Height="4" Background="#40ffffff" VerticalAlignment="Bottom">
                                                <Border Width="140" Background="{DynamicResource MdSysColor.Primary}" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="16">
                                        <TextBlock Text="The Office" Style="{DynamicResource MdSysTypescale.TitleMedium}"/>
                                        <TextBlock Text="S3 E12 • Traveling Salesmen" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Video Card 3 -->
                            <Border Width="280" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="156"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0">
                                        <Grid><Border Background="#80000000" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                <TextBlock Text="12:45 / 45:00" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="White"/>
                                            </Border>
                                            <Border Height="4" Background="#40ffffff" VerticalAlignment="Bottom">
                                                <Border Width="78" Background="{DynamicResource MdSysColor.Primary}" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="16">
                                        <TextBlock Text="Planet Earth III" Style="{DynamicResource MdSysTypescale.TitleMedium}"/>
                                        <TextBlock Text="E3 • Freshwater" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Video Card 4 -->
                            <Border Width="280" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="156"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0">
                                        <Grid><Border Background="#80000000" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12">
                                                <TextBlock Text="38:20 / 50:00" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="White"/>
                                            </Border>
                                            <Border Height="4" Background="#40ffffff" VerticalAlignment="Bottom">
                                                <Border Width="198" Background="{DynamicResource MdSysColor.Primary}" HorizontalAlignment="Left"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="16">
                                        <TextBlock Text="Breaking Bad" Style="{DynamicResource MdSysTypescale.TitleMedium}"/>
                                        <TextBlock Text="S5 E14 • Ozymandias" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <!-- Trending Now -->
                <StackPanel Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Trending Now" Style="{DynamicResource MdSysTypescale.TitleLarge}"/>
                        <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="See All" Margin="12,0,0,0"/>
                    </StackPanel>
                    
                    <WrapPanel>
                        <!-- Movie Card 1 -->
                        <Border Width="200" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="280" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0"></Border>
                                <StackPanel Margin="12">
                                    <TextBlock Text="Oppenheimer" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="8.9" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Movie Card 2 -->
                        <Border Width="200" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="280" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0"></Border>
                                <StackPanel Margin="12">
                                    <TextBlock Text="Barbie" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="7.2" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Movie Card 3 -->
                        <Border Width="200" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="280" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0"></Border>
                                <StackPanel Margin="12">
                                    <TextBlock Text="Spider-Man" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="8.4" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Movie Card 4 -->
                        <Border Width="200" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="280" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0"></Border>
                                <StackPanel Margin="12">
                                    <TextBlock Text="John Wick 4" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="7.8" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Movie Card 5 -->
                        <Border Width="200" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Margin="0,0,16,16">
                            <StackPanel>
                                <Border Height="280" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8,8,0,0"></Border>
                                <StackPanel Margin="12">
                                    <TextBlock Text="Guardians 3" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="8.0" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <!-- My List -->
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="My List" Style="{DynamicResource MdSysTypescale.TitleLarge}"/>
                        <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="Manage" Margin="12,0,0,0"/>
                    </StackPanel>
                    
                    <ListBox Style="{DynamicResource MaterialDesignListBoxStyle}" BorderThickness="0" ScrollViewer.CanContentScroll="False">
                        <!-- List Item 1 -->
                        <ListBoxItem Style="{DynamicResource MaterialDesignListBoxItemStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="120" Height="68" CornerRadius="4" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}"></Border>
                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                    <TextBlock Text="The Last of Us" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <TextBlock Text="S1 • Drama • 2023" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}" Padding="16,8">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="Play"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" Margin="8,0,0,0"></Button>
                                </StackPanel>
                            </Grid>
                        </ListBoxItem>

                        <!-- List Item 2 -->
                        <ListBoxItem Style="{DynamicResource MaterialDesignListBoxItemStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="120" Height="68" CornerRadius="4" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}"></Border>
                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                    <TextBlock Text="Wednesday" Style="{DynamicResource MdSysTypescale.TitleSmall}"/>
                                    <TextBlock Text="S1 • Comedy • 2022" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}" Padding="16,8">
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="Play"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" Margin="8,0,0,0"></Button>
                                </StackPanel>
                            </Grid>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
