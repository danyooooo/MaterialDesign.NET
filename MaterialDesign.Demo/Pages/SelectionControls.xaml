<UserControl x:Class="MaterialDesign.Demo.Pages.SelectionControls"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers;assembly=MaterialDesign.NET"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Selection Controls" Style="{DynamicResource MdSysTypescale.DisplaySmall}" Margin="0,0,0,8" />
            <TextBlock Text="Selection controls allow users to select options, make decisions, and set preferences." Style="{DynamicResource MdSysTypescale.BodyLarge}" Margin="0,0,0,32" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" TextWrapping="Wrap" />

            <!-- ComboBox (Select) -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Select (ComboBox)" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,16">
                            <StackPanel Margin="0,0,24,24">
                                <TextBlock Text="Filled" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ComboBox Style="{DynamicResource MaterialDesignFilledComboBoxStyle}" 
                                          helpers:TextFieldAssist.Label="Label"
                                          Width="240">
                                    <ComboBoxItem>Option 1</ComboBoxItem>
                                    <ComboBoxItem>Option 2</ComboBoxItem>
                                    <ComboBoxItem>Option 3</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>

                             <StackPanel Margin="0,0,24,24">
                                <TextBlock Text="Outlined" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ComboBox Style="{DynamicResource MaterialDesignOutlinedComboBoxStyle}" 
                                          helpers:TextFieldAssist.Label="Label"
                                          Width="240">
                                    <ComboBoxItem>Option 1</ComboBoxItem>
                                    <ComboBoxItem>Option 2</ComboBoxItem>
                                    <ComboBoxItem>Option 3</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                            
                             <StackPanel Margin="0,0,24,24">
                                <TextBlock Text="Disabled" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ComboBox Style="{DynamicResource MaterialDesignFilledComboBoxStyle}" 
                                          helpers:TextFieldAssist.Label="Label"
                                          IsEnabled="False"
                                          Width="240"/>
                            </StackPanel>
                        </WrapPanel>
                        
                        <Expander Header="Source Code">
                            <TextBox Style="{DynamicResource MaterialDesignOutlinedTextBoxStyle}"
                                     helpers:TextFieldAssist.Label="XAML"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Text="&lt;ComboBox Style=&quot;{DynamicResource MaterialDesignFilledComboBoxStyle}&quot;&#x0a;          helpers:TextFieldAssist.Label=&quot;Label&quot; /&gt;" />
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Checkbox -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Checkbox" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,16">
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Unchecked" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <CheckBox Style="{DynamicResource MaterialDesignCheckboxStyle}" Content="Checkbox" />
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Checked" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <CheckBox Style="{DynamicResource MaterialDesignCheckboxStyle}" Content="Checkbox" IsChecked="True" />
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Indeterminate" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <CheckBox Style="{DynamicResource MaterialDesignCheckboxStyle}" Content="Checkbox" IsChecked="{x:Null}" />
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Disabled" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <CheckBox Style="{DynamicResource MaterialDesignCheckboxStyle}" Content="Checkbox" IsEnabled="False" />
                            </StackPanel>
                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Disabled Checked" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <CheckBox Style="{DynamicResource MaterialDesignCheckboxStyle}" Content="Checkbox" IsEnabled="False" IsChecked="True" />
                            </StackPanel>
                        </WrapPanel>
                        
                        <Expander Header="Source Code">
                            <TextBox Style="{DynamicResource MaterialDesignOutlinedTextBoxStyle}"
                                     helpers:TextFieldAssist.Label="XAML"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Text="&lt;CheckBox Style=&quot;{DynamicResource MaterialDesignCheckboxStyle}&quot;&#x0a;         Content=&quot;Checkbox&quot; /&gt;" />
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Switch -->
             <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Switch" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,16">
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Off" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ToggleButton Style="{DynamicResource MaterialDesignSwitchStyle}" />
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="On" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ToggleButton Style="{DynamicResource MaterialDesignSwitchStyle}" IsChecked="True" />
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Disabled Off" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ToggleButton Style="{DynamicResource MaterialDesignSwitchStyle}" IsEnabled="False" />
                            </StackPanel>
                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Disabled On" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <ToggleButton Style="{DynamicResource MaterialDesignSwitchStyle}" IsEnabled="False" IsChecked="True" />
                            </StackPanel>
                        </WrapPanel>

                        <Expander Header="Source Code">
                            <TextBox Style="{DynamicResource MaterialDesignOutlinedTextBoxStyle}"
                                     helpers:TextFieldAssist.Label="XAML"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Text="&lt;ToggleButton Style=&quot;{DynamicResource MaterialDesignSwitchStyle}&quot; /&gt;" />
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- RadioButton -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="Radio Button" Style="{DynamicResource MdSysTypescale.HeadlineSmall}" Margin="0,0,0,16" />
                <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                    <StackPanel>
                         <WrapPanel Margin="0,0,0,16">
                            <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Group 1" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                <StackPanel>
                                    <RadioButton Style="{DynamicResource MaterialDesignRadioButtonStyle}" Content="Option 1" GroupName="G1" IsChecked="True" Margin="0,0,0,8"/>
                                    <RadioButton Style="{DynamicResource MaterialDesignRadioButtonStyle}" Content="Option 2" GroupName="G1" />
                                </StackPanel>
                            </StackPanel>

                             <StackPanel Margin="0,0,32,0">
                                <TextBlock Text="Disabled" Style="{DynamicResource MdSysTypescale.TitleSmall}" Margin="0,0,0,8"/>
                                 <StackPanel>
                                    <RadioButton Style="{DynamicResource MaterialDesignRadioButtonStyle}" Content="Option 1" IsEnabled="False" IsChecked="True" Margin="0,0,0,8"/>
                                    <RadioButton Style="{DynamicResource MaterialDesignRadioButtonStyle}" Content="Option 2" IsEnabled="False" />
                                </StackPanel>
                            </StackPanel>
                        </WrapPanel>

                        <Expander Header="Source Code">
                            <TextBox Style="{DynamicResource MaterialDesignOutlinedTextBoxStyle}"
                                     helpers:TextFieldAssist.Label="XAML"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     Height="80"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Text="&lt;RadioButton Style=&quot;{DynamicResource MaterialDesignRadioButtonStyle}&quot;&#x0a;             Content=&quot;Option 1&quot; GroupName=&quot;G1&quot; /&gt;" />
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
