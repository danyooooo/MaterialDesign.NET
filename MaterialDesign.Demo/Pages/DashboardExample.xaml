<UserControl x:Class="MaterialDesign.Demo.Pages.DashboardExample"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers;assembly=MaterialDesign.NET"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400">
    <Grid Background="{DynamicResource MdSysColor.Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top App Bar -->
        <Border Grid.Row="0" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="20,16" BorderBrush="{DynamicResource MdSysColor.OutlineVariant}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Dashboard" Style="{DynamicResource MdSysTypescale.HeadlineMedium}"/>
                    <TextBlock Text="Welcome back, John! Here's what's happening today." Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="Last 30 days" Style="{DynamicResource MdSysTypescale.BodyMedium}"/></StackPanel>
                    </Border>
                    <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">
                <!-- Stats Cards -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Stat Card 1 -->
                    <Border Grid.Column="0" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.PrimaryContainer}" Padding="20" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Total Revenue" Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="$48,295" Style="{DynamicResource MdSysTypescale.HeadlineMedium}" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}" Margin="0,12,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{DynamicResource MdSysColor.Primary}" CornerRadius="4" Padding="4,2">
                                    <TextBlock Text="+12.5%" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnPrimary}"/>
                                </Border>
                                <TextBlock Text="vs last month" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stat Card 2 -->
                    <Border Grid.Column="1" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SecondaryContainer}" Padding="20" Margin="12,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Active Users" Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnSecondaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="2,845" Style="{DynamicResource MdSysTypescale.HeadlineMedium}" Foreground="{DynamicResource MdSysColor.OnSecondaryContainer}" Margin="0,12,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{DynamicResource MdSysColor.Secondary}" CornerRadius="4" Padding="4,2">
                                    <TextBlock Text="+8.2%" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnSecondary}"/>
                                </Border>
                                <TextBlock Text="vs last month" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSecondaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stat Card 3 -->
                    <Border Grid.Column="2" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.TertiaryContainer}" Padding="20" Margin="12,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Orders" Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnTertiaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="1,234" Style="{DynamicResource MdSysTypescale.HeadlineMedium}" Foreground="{DynamicResource MdSysColor.OnTertiaryContainer}" Margin="0,12,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{DynamicResource MdSysColor.Tertiary}" CornerRadius="4" Padding="4,2">
                                    <TextBlock Text="+23.1%" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnTertiary}"/>
                                </Border>
                                <TextBlock Text="vs last month" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnTertiaryContainer}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stat Card 4 -->
                    <Border Grid.Column="3" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="20" Margin="12,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="Conversion" Style="{DynamicResource MdSysTypescale.BodyMedium}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="3.24%" Style="{DynamicResource MdSysTypescale.HeadlineMedium}" Foreground="{DynamicResource MdSysColor.OnSurface}" Margin="0,12,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{DynamicResource MdSysColor.ErrorContainer}" CornerRadius="4" Padding="4,2">
                                    <TextBlock Text="-2.4%" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnErrorContainer}"/>
                                </Border>
                                <TextBlock Text="vs last month" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts and Tables -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Revenue Chart -->
                    <Border Grid.Column="0" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="20" Margin="0,0,16,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Revenue Overview" Style="{DynamicResource MdSysTypescale.TitleLarge}"/>
                                <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" Margin="8,0,0,0"></Button>
                            </StackPanel>

                            <!-- Chart Placeholder -->
                            <Border Height="250" Background="{DynamicResource MdSysColor.SurfaceContainerHighest}" CornerRadius="8" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Bars -->
                                    <Border Grid.Column="0" Background="{DynamicResource MdSysColor.Primary}" Opacity="0.6" Height="120" VerticalAlignment="Bottom" Margin="8,0"/>
                                    <Border Grid.Column="1" Background="{DynamicResource MdSysColor.Primary}" Opacity="0.8" Height="160" VerticalAlignment="Bottom" Margin="8,0"/>
                                    <Border Grid.Column="2" Background="{DynamicResource MdSysColor.Primary}" Height="200" VerticalAlignment="Bottom" Margin="8,0"/>
                                    <Border Grid.Column="3" Background="{DynamicResource MdSysColor.Primary}" Opacity="0.7" Height="140" VerticalAlignment="Bottom" Margin="8,0"/>
                                    <Border Grid.Column="4" Background="{DynamicResource MdSysColor.Primary}" Height="180" VerticalAlignment="Bottom" Margin="8,0"/>
                                    <Border Grid.Column="5" Background="{DynamicResource MdSysColor.Primary}" Opacity="0.9" Height="220" VerticalAlignment="Bottom" Margin="8,0"/>

                                    <!-- Labels -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mon" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Tue" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Wed" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Thu" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Fri" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="5" Text="Sat" Style="{DynamicResource MdSysTypescale.BodySmall}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Primary}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="This month" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Primary}" Opacity="0.4" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Last month" Style="{DynamicResource MdSysTypescale.BodySmall}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Traffic Sources -->
                    <Border Grid.Column="1" CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Traffic Sources" Style="{DynamicResource MdSysTypescale.TitleLarge}" Margin="0,0,0,16"/>

                            <!-- Progress items -->
                            <StackPanel Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Primary}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Direct" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Text="45%" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="Auto,0,0,0"/>
                                </StackPanel>
                                <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" Value="45" Maximum="100"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Secondary}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Social" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Text="32%" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="Auto,0,0,0"/>
                                </StackPanel>
                                <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" Value="32" Maximum="100"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Tertiary}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Organic" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Text="18%" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="Auto,0,0,0"/>
                                </StackPanel>
                                <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" Value="18" Maximum="100"/>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="12" Height="12" Background="{DynamicResource MdSysColor.Error}" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Referral" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Text="5%" Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="Auto,0,0,0"/>
                                </StackPanel>
                                <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}" Value="5" Maximum="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Orders Table -->
                <Border CornerRadius="{DynamicResource MdSysShape.CornerMedium}" Background="{DynamicResource MdSysColor.SurfaceContainer}" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Recent Orders" Style="{DynamicResource MdSysTypescale.TitleLarge}"/>
                            <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="View All" Margin="12,0,0,0"/>
                        </StackPanel>

                        <ListBox Style="{DynamicResource MaterialDesignListBoxStyle}" BorderThickness="0" ScrollViewer.CanContentScroll="False">
                            <!-- Header -->
                            <ListBoxItem IsEnabled="False">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Order ID" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    <TextBlock Grid.Column="1" Text="Customer" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    <TextBlock Grid.Column="2" Text="Date" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    <TextBlock Grid.Column="3" Text="Amount" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                    <TextBlock Grid.Column="4" Text="Status" Style="{DynamicResource MdSysTypescale.LabelLarge}" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}"/>
                                </Grid>
                            </ListBoxItem>

                            <!-- Order 1 -->
                            <ListBoxItem Style="{DynamicResource MaterialDesignListBoxItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#ORD-001" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource MdSysColor.PrimaryContainer}" Margin="0,0,8,0">
                                            <TextBlock Text="JD" Style="{DynamicResource MdSysTypescale.BodySmall}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}"/>
                                        </Border>
                                        <TextBlock Text="John Doe" Style="{DynamicResource MdSysTypescale.BodyMedium}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Mar 15, 2025" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Grid.Column="3" Text="$249.99" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <Border Grid.Column="4" Background="{DynamicResource MdSysColor.SuccessContainer}" CornerRadius="12" Padding="12,4">
                                        <TextBlock Text="Completed" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnSuccessContainer}"/>
                                    </Border>
                                </Grid>
                            </ListBoxItem>

                            <!-- Order 2 -->
                            <ListBoxItem Style="{DynamicResource MaterialDesignListBoxItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#ORD-002" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource MdSysColor.SecondaryContainer}" Margin="0,0,8,0">
                                            <TextBlock Text="SM" Style="{DynamicResource MdSysTypescale.BodySmall}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource MdSysColor.OnSecondaryContainer}"/>
                                        </Border>
                                        <TextBlock Text="Sarah Miller" Style="{DynamicResource MdSysTypescale.BodyMedium}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Mar 15, 2025" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Grid.Column="3" Text="$189.50" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <Border Grid.Column="4" Background="{DynamicResource MdSysColor.SecondaryContainer}" CornerRadius="12" Padding="12,4">
                                        <TextBlock Text="Processing" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnSecondaryContainer}"/>
                                    </Border>
                                </Grid>
                            </ListBoxItem>

                            <!-- Order 3 -->
                            <ListBoxItem Style="{DynamicResource MaterialDesignListBoxItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#ORD-003" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="{DynamicResource MdSysColor.TertiaryContainer}" Margin="0,0,8,0">
                                            <TextBlock Text="MJ" Style="{DynamicResource MdSysTypescale.BodySmall}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource MdSysColor.OnTertiaryContainer}"/>
                                        </Border>
                                        <TextBlock Text="Mike Johnson" Style="{DynamicResource MdSysTypescale.BodyMedium}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="Mar 14, 2025" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <TextBlock Grid.Column="3" Text="$599.00" Style="{DynamicResource MdSysTypescale.BodyMedium}"/>
                                    <Border Grid.Column="4" Background="{DynamicResource MdSysColor.PrimaryContainer}" CornerRadius="12" Padding="12,4">
                                        <TextBlock Text="Shipped" Style="{DynamicResource MdSysTypescale.LabelSmall}" Foreground="{DynamicResource MdSysColor.OnPrimaryContainer}"/>
                                    </Border>
                                </Grid>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
