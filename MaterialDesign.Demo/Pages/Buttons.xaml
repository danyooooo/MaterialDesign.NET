<UserControl x:Class="MaterialDesign.Demo.Pages.Buttons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:MaterialDesign.NET.Helpers;assembly=MaterialDesign.NET"
             xmlns:controls="clr-namespace:MaterialDesign.NET.Controls;assembly=MaterialDesign.NET"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Buttons" Style="{DynamicResource MdSysTypescale.DisplaySmall}" Margin="0,0,0,8" />
            <TextBlock Text="Buttons allow users to take actions, and make choices, with a single tap." Style="{DynamicResource MdSysTypescale.BodyLarge}" Margin="0,0,0,32" Foreground="{DynamicResource MdSysColor.OnSurfaceVariant}" TextWrapping="Wrap" />

            <!-- Common Buttons Showcase -->
            <ItemsControl>
                <ItemsControl.ItemsPanel>
                   <ItemsPanelTemplate>
                        <StackPanel />
                   </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <!-- Filled -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Filled Button" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}" Content="Enabled" Margin="0,0,16,0" Width="120" />
                                <Button Style="{DynamicResource MaterialDesignFilledButtonStyle}" Content="Disabled" IsEnabled="False" Width="120" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Elevated -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Elevated Button" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{DynamicResource MaterialDesignElevatedButtonStyle}" Content="Enabled" Margin="0,0,16,0" Width="120" />
                                <Button Style="{DynamicResource MaterialDesignElevatedButtonStyle}" Content="Disabled" IsEnabled="False" Width="120" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Tonal -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Tonal Button" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{DynamicResource MaterialDesignTonalButtonStyle}" Content="Enabled" Margin="0,0,16,0" Width="120" />
                                <Button Style="{DynamicResource MaterialDesignTonalButtonStyle}" Content="Disabled" IsEnabled="False" Width="120" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Outlined -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Outlined Button" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{DynamicResource MaterialDesignOutlinedButtonStyle}" Content="Enabled" Margin="0,0,16,0" Width="120" />
                                <Button Style="{DynamicResource MaterialDesignOutlinedButtonStyle}" Content="Disabled" IsEnabled="False" Width="120" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Text -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Text Button" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="Enabled" Margin="0,0,16,0" Width="120" />
                                <Button Style="{DynamicResource MaterialDesignTextButtonStyle}" Content="Disabled" IsEnabled="False" Width="120" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Icon Buttons -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Icon Buttons" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,8"/>
                     <Border Background="{DynamicResource MdSysColor.SurfaceContainer}" CornerRadius="12" Padding="24">
                        <StackPanel>
                            <WrapPanel>
                                <!-- Standard -->
                                <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" ToolTip="Standard" Margin="0,0,16,0">
                                    <controls:PackIcon Kind="Settings" Width="24" Height="24"/>
                                </Button>
                                <!-- Filled -->
                                <Button Style="{DynamicResource MaterialDesignFilledIconButtonStyle}" ToolTip="Filled" Margin="0,0,16,0">
                                    <controls:PackIcon Kind="Add" Width="24" Height="24"/>
                                </Button>
                                <!-- Filled Tonal -->
                                <Button Style="{DynamicResource MaterialDesignFilledTonalIconButtonStyle}" ToolTip="Filled Tonal" Margin="0,0,16,0">
                                    <controls:PackIcon Kind="Edit" Width="24" Height="24"/>
                                </Button>
                                <!-- Outlined -->
                                <Button Style="{DynamicResource MaterialDesignOutlinedIconButtonStyle}" ToolTip="Outlined" Margin="0,0,16,0">
                                    <controls:PackIcon Kind="Delete" Width="24" Height="24"/>
                                </Button>
                                <!-- Disabled -->
                                <Button Style="{DynamicResource MaterialDesignIconButtonStyle}" IsEnabled="False" ToolTip="Disabled" Margin="0,0,16,0">
                                    <controls:PackIcon Kind="Settings" Width="24" Height="24"/>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
