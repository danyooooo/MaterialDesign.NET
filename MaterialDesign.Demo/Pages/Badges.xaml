<UserControl x:Class="MaterialDesign.Demo.Pages.Badges"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MaterialDesign.Demo.Pages"
             xmlns:md="clr-namespace:MaterialDesign.NET.Controls;assembly=MaterialDesign.NET"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16" MaxWidth="800" HorizontalAlignment="Left">
                <TextBlock Text="Badges" Style="{DynamicResource MdSysTypescale.DisplayMedium}" Margin="0,0,0,24" />
                <TextBlock Text="Badges show notifications, counts, or status information." 
                           Style="{DynamicResource MdSysTypescale.BodyMedium}" Margin="0,0,0,32" />

                <!-- Small Badge (Dot) -->
                <TextBlock Text="Small Badge (Dot)" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,16" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <md:Badge Margin="0,0,32,0"></md:Badge>

                    <md:Badge Margin="0,0,32,0" BadgeBackground="{DynamicResource MdSysColor.Primary}"></md:Badge>
                </StackPanel>

                <!-- Large Badge (Label) -->
                <TextBlock Text="Large Badge (Label)" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,16" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <md:Badge BadgeContent="1" Margin="0,0,32,0"></md:Badge>

                    <md:Badge BadgeContent="99+" Margin="0,0,32,0"></md:Badge>
                    
                     <md:Badge BadgeContent="New" BadgeBackground="{DynamicResource MdSysColor.Tertiary}" BadgeForeground="{DynamicResource MdSysColor.OnTertiary}">
                        <Button Content="Mail" />
                    </md:Badge>
                </StackPanel>

                <!-- Interactive Demo -->
                <TextBlock Text="Interactive Demo" Style="{DynamicResource MdSysTypescale.TitleMedium}" Margin="0,0,0,16" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <md:Badge x:Name="InteractiveBadge" BadgeContent="0" Margin="0,0,32,0">
                         <Button Content="Click Me" Click="Button_Click" />
                    </md:Badge>
                    
                    <CheckBox Content="Show Badge" IsChecked="{Binding ShowBadge, ElementName=InteractiveBadge}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
